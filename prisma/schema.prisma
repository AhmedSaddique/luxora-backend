generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
}

model Admin {
  id String @id @default(uuid()) @db.Uuid

  name         String
  email        String    @unique
  password     String
  role         AdminRole @default(ADMIN)
  permissions  String[]  @default([]) // Store permissions as an array of strings
  lastEditedBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String  @id @default(uuid()) @db.Uuid
  name     String
  email    String  @unique
  password String
  phone    String?

  // Password reset (random token + expiry, single-use)
  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
  orders    Order[]
}

model Address {
  id          String  @id @default(uuid()) @db.Uuid
  userId      String  @db.Uuid
  fullName    String
  phone       String
  addressLine String
  city        String
  area        String?
  isDefault   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id          String @id @default(uuid()) @db.Uuid
  orderNumber String @unique
  trackingId  String @unique

  // Null for guest checkout (order without an account).
  userId String? @db.Uuid

  // Delivery address snapshot (no billing address).
  customerName String
  email        String
  phone        String
  addressLine  String
  city         String
  area         String?
  note         String?

  // Amounts (PKR)
  subtotal      Decimal       @db.Decimal(10, 2)
  shippingFee   Decimal       @default(250) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(COD)
  status        OrderStatus   @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @db.Uuid
  productId String? @db.Uuid
  name      String
  image     String?
  price     Decimal @db.Decimal(10, 2)
  quantity  Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Category {
  // Primary Key
  id String @id @default(uuid()) @db.Uuid

  // Core fields
  name            String        @unique
  description     String        @db.Text()
  breadcrumb      String
  path            String        @unique
  posterImage     Json          @default("{\"imageUrl\": \"https://placehold.co/600x600?text=Product+Image\"}")
  bannerImage     Json?
  metaTitle       String
  metaDescription String
  canonicalUrl    String
  seoSchema       String?       @db.Text()
  lastEditedBy    String
  status          ContentStatus @default(PUBLISHED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products      Product[]     @relation(name: "CategoryProducts")
  subcategories Subcategory[] @relation(name: "CategorySubcategories")
  blogs         Blog[]        @relation(name: "CategoryBlogs")
}

model Subcategory {
  // Primary Key
  id         String @id @default(uuid()) @db.Uuid
  categoryId String @db.Uuid

  // Core fields
  name            String        @unique
  description     String        @db.Text()
  breadcrumb      String
  path            String        @unique
  posterImage     Json          @default("{\"imageUrl\": \"https://placehold.co/600x600?text=Product+Image\"}")
  bannerImage     Json?
  metaTitle       String
  metaDescription String
  canonicalUrl    String
  seoSchema       String?       @db.Text()
  lastEditedBy    String
  status          ContentStatus @default(PUBLISHED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  category Category  @relation(name: "CategorySubcategories", fields: [categoryId], references: [id], onDelete: Restrict)
  products Product[] @relation(name: "SubcategoryProducts")
}

model Product {
  id                    String        @id @default(uuid()) @db.Uuid
  categoryId            String        @db.Uuid
  subcategoryId         String?       @db.Uuid
  name                  String
  description           String        @db.Text()
  breadcrumb            String
  path                  String        @unique
  price                 Decimal       @db.Decimal(10, 2)
  discountPrice         Decimal?      @db.Decimal(10, 2)
  stock                 Int           @default(0)
  posterImage           Json          @default("{\"imageUrl\": \"https://placehold.co/600x600?text=Product+Image\"}")
  productImages         Json[]        @default([])
  additionalInformation Json[]        @default([])
  metaTitle             String?       @db.Text()
  metaDescription       String?       @db.Text()
  canonicalUrl          String?
  seoSchema             String?       @db.Text()
  lastEditedBy          String
  status                ContentStatus @default(PUBLISHED)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  category    Category     @relation(name: "CategoryProducts", fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory Subcategory? @relation(name: "SubcategoryProducts", fields: [subcategoryId], references: [id], onDelete: Restrict)
}

model Contact {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  phone     String
  whatsapp  String
  message   String
  createdAt DateTime @default(now())
}

model Blog {
  id          String @id @default(uuid()) @db.Uuid
  categoryId  String @db.Uuid
  title       String
  path        String @unique
  posterImage Json
  bannerImage Json
  content     String @db.Text()

  // SEO Fields
  metaTitle       String? @db.Text()
  metaDescription String? @db.Text()
  canonicalUrl    String?
  imageAltText    String?
  seoSchema       String? @db.Text()

  // Common Fields
  lastEditedBy String
  status       ContentStatus @default(PUBLISHED)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  category Category @relation(name: "CategoryBlogs", fields: [categoryId], references: [id], onDelete: Restrict)
}

model Testimonial {
  id          String @id @default(uuid()) @db.Uuid
  name        String
  designation String
  rating      Int    @default(5)
  description String @db.Text()

  lastEditedBy String
  status       ContentStatus @default(PUBLISHED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
